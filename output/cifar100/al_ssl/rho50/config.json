{
  "dataset": "cifar100",
  "budget_level": "ultra_low",
  "model_type": "simplecnn",
  "n_initial": 100,
  "n_query": 100,
  "n_rounds": 10,
  "seeds": [
    42
  ],
  "strategies": [
    "random",
    "entropy",
    "margin",
    "coreset",
    "badge",
    "qbc"
  ],
  "use_ssl": true,
  "ssl_method": "flexmatch",
  "ssl_method_requested": "flexmatch",
  "full_supervised_epochs": 50,
  "early_stopping_patience": 5,
  "use_scheduler": true,
  "imbalance_ratio": 50.0,
  "cold_start": false,
  "ablation": "",
  "bald_mc_samples": 10,
  "fast_4060_preset": true,
  "qbc_reuse_committee": true,
  "qbc_incremental_epochs": 1,
  "max_pool_subsample": 3000,
  "full_supervised_train_size": 12608,
  "ssl_lambda_u_warmup_epochs": 10,
  "ts_jitter_std": 0.03,
  "ts_scaling_std": 0.1,
  "ts_time_warp_sigma": 0.05,
  "ts_use_time_warp": true,
  "dropout_consistency_passes": 2,
  "vat_epsilon": 1.0,
  "use_amp": true,
  "class_aware_lambda": 0.5,
  "curriculum_warmup_rounds": 5,
  "pseudo_refresh_freq": 0,
  "ssl_warmup_rounds": 0,
  "ssl_adaptive": false,
  "ssl_adaptive_threshold": 0.8,
  "pretrained_features": ""
}